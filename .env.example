# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# AWS Secrets Manager ARNs
# Replace with your actual secret ARNs after creating them in Secrets Manager
PRIVATE_KEY_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:sdd-crypto/private-key-XXXXXX
PUBLIC_KEY_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:sdd-crypto/public-key-XXXXXX

# SAM Deployment
STACK_NAME=sdd-crypto-lambdas
STAGE_NAME=dev

# API Gateway (populated after deployment)
API_BASE_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/dev
